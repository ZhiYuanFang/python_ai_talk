# =============================================================================
# 环境变量模板 - python_ai_talk
# 命名规范：三层一致（.env 文件、docker-compose 注入、python 应用读取同名变量）
# =============================================================================
# 使用方式：
#   1. 复制本文件为对应环境的 .env 文件：
#      cp .env.example env/.env.local   # 本地开发
#      cp .env.example env/.env.test    # 测试环境
#      cp .env.example env/.env.prod    # 生产环境
#   2. 修改对应文件中的变量值
#   3. 启动服务（详见 docs/deploy-guide.md）
# =============================================================================

# --- 镜像配置（仅测试/生产环境需要）---
REGISTRY=crpi-lff3xynwzvqxxxjk-vpc.cn-hangzhou.personal.cr.aliyuncs.com/pangbao-test
IMAGE_TAG=v2.0.7-beta.43
ACR_USERNAME=your_acr_username
ACR_PASSWORD=your_acr_password

# --- 兄弟仓服务地址 ---
# 本地开发：http://host.docker.internal:9801
# 测试/生产：http://history-service:9801
HISTORY_SERVICE_URL=http://host.docker.internal:9801
DEVICE_SERVICE_URL=http://host.docker.internal:9803
VOICE_SERVICE_URL=http://host.docker.internal:9802

# --- Redis 配置 ---
# 本地开发：redis://localhost:6379/0
# 测试环境：redis://redis-test:6379/0
# 生产环境：redis://redis-node-1:7001,redis-node-2:7002,redis-node-3:7003
REDIS_URL=redis://localhost:6379/0

# --- AI：密钥（必填，与 go_ai_talk 兄弟仓共用）---
DEEPSEEK_API_KEY=your_deepseek_api_key
GLM_API_KEY=your_glm_api_key

# --- 向量数据库配置 ---
CHROMA_PERSIST_DIR=/app/data/chroma_db
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
